# Copy this file to ".env" and fill in your values.
# (.env is git-ignored and must never be committed.)

# --- LLM (Anthropic Claude) ---
# Required for intent understanding + detail extraction.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model. Default is claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: reasoning effort for the LLM (low | medium | high). Default: low.
# ANTHROPIC_EFFORT=low

# --- Agent behaviour ---
# Look-back window for scanning the inbox (Gmail "newer_than" syntax). Default: 2d.
# LOOKBACK=2d

# Default meeting duration in minutes when the email doesn't state one. Default: 60.
# DEFAULT_DURATION_MINUTES=60

# IANA timezone used when creating events / interpreting times. Default: Asia/Jerusalem.
# TIMEZONE=Asia/Jerusalem

# --- Google account ---
# The Gmail address you granted API access to (added as a Test user).
# If left unset, the agent asks for it on first run and saves it here.
# It pre-selects the correct account on the Google consent screen.
# USER_EMAIL=you@gmail.com

# --- Google OAuth file locations (relative to the project root) ---
# These are the defaults; change only if you keep the files elsewhere.
# CREDENTIALS_FILE=credentials.json
# TOKEN_FILE=token.json
